{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "format": "uri", "description": "URL to user's profile picture" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User's role in the application" },
        "settings": { 
          "type": "object", 
          "description": "User's personalized settings",
          "properties": {
            "theme": { "type": "string", "enum": ["light", "dark", "solarized"], "description": "UI theme preference" },
            "autoAnalyze": { "type": "boolean", "description": "Whether to auto-analyze on file selection" }
          }
        }
      },
      "required": ["uid", "email"]
    },
    "HistoryItem": {
      "title": "History Item",
      "description": "A record of a metadata analysis action",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fileName": { "type": "string" },
        "fileType": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "source": { "type": "string", "enum": ["file", "url"] },
        "summary": { "type": "string", "description": "Brief summary of metadata found" }
      },
      "required": ["fileName", "timestamp", "source"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles and settings"
    },
    "/users/{userId}/history/{historyId}": {
      "schema": "HistoryItem",
      "description": "Subcollection of user's analysis history"
    },
    "/admins/{adminId}": {
      "schema": "User",
      "description": "Collection of system administrators"
    }
  }
}
