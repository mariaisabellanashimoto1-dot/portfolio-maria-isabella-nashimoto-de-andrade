rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Note: Admin check would require a separate admins collection or custom claims.
    // For this app, we'll keep it simple or assume a privileged collection.
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 200 &&
             data.role in ['user', 'admin'] &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 500)) &&
             (!('settings' in data) || (
               data.settings is map &&
               (!('theme' in data.settings) || data.settings.theme in ['light', 'dark', 'solarized']) &&
               (!('autoAnalyze' in data.settings) || data.settings.autoAnalyze is bool)
             ));
    }

    function isValidHistoryItem(data) {
      return data.keys().hasAll(['fileName', 'timestamp', 'source']) &&
             data.fileName is string && data.fileName.size() <= 255 &&
             data.timestamp is string && // Code uses ISO string for now, but rules suggest serverTimestamp is better
             data.source in ['file', 'url'] &&
             (!('fileType' in data) || (data.fileType is string && data.fileType.size() <= 100)) &&
             (!('summary' in data) || (data.summary is string && data.summary.size() <= 2000)) &&
             (!('id' in data) || (data.id is string && data.id.size() <= 128));
    }

    // --- Collection Matches ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        // Action: Update Settings
        (incoming().diff(existing()).affectedKeys().hasOnly(['settings'])) ||
        // Action: Profile Detail Update (excluding role)
        (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'settings']))
      ) && incoming().role == existing().role; // Users can't change their own role
      allow delete: if false; // Profiles are permanent for now

      match /history/{historyId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidHistoryItem(incoming());
        allow update: if false; // History is immutable
        allow delete: if isOwner(userId);
      }
    }

    // Admins collection for role checks
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Provisioned via console/backend
    }
  }
}
